{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "choose-browser",
  "title": "Choose Browser",
  "description": "List all installed browsers and set one as your macOS default",
  "icon": "extension-icon.png",
  "author": "aryankush25",
  "categories": ["Web"],
  "license": "MIT",
  "commands": [
    {
      "name": "index",
      "title": "Choose Default Browser",
      "description": "Set any installed browser as your macOS default",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.85.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/node": "20.8.10",
    "@types/react": "19.0.10",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "typescript": "^5.4.5"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  }
}
